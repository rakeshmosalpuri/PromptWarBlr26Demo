# Copy this to .env and fill in your values. NEVER commit .env to Git.

# ── Google Gemini AI ──────────────────────────────────────────────
# Get key: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Maps JavaScript API ────────────────────────────────────
# Enable "Maps JavaScript API" at: https://console.cloud.google.com/apis
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Google Cloud Translation API ─────────────────────────────────
# Enable "Cloud Translation API" at: https://console.cloud.google.com/apis
VITE_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# ── Firebase / Firestore ──────────────────────────────────────────
# Get config: https://console.firebase.google.com > Project Settings > Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
